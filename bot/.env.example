# ── Telegram ──────────────────────────────────────────────────────
# Token from @BotFather (https://t.me/BotFather → /newbot).
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Numeric Telegram user id allowed to use /up and /down.
# Get it from @userinfobot. Every other user is silently ignored.
ALLOWED_TELEGRAM_USER_ID=123456789

# ── Local execution ───────────────────────────────────────────────
# Python interpreter used to spawn the agent. On Windows this is usually
# "python" or the absolute path to the agent's venv python.exe.
PYTHON_BIN=python
