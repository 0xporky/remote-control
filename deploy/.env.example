# ── DigitalOcean ──────────────────────────────────────────────────
# Create at: https://cloud.digitalocean.com/account/api/tokens
# Needs read+write on droplets and domains.
DO_API_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

DO_REGION=fra1
DO_SIZE=s-1vcpu-1gb
DO_IMAGE=ubuntu-24-04-x64

# Fingerprint of an SSH key already uploaded to DigitalOcean.
# List with: doctl compute ssh-key list
DO_SSH_KEY_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99

# Local path to the matching private key (used for SSH/rsync into the droplet).
SSH_PRIVATE_KEY=~/.ssh/id_ed25519

# ── DNS ────────────────────────────────────────────────────────────
# The domain must already be managed by DigitalOcean DNS.
# Confirm with: doctl compute domain list
DOMAIN=example.com
SUBDOMAIN=rc
DNS_TTL=60

# ── App runtime (server) ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING

AUTH_PASSWORD=CHANGE_ME

AGENT_TOKEN_REQUIRED=true
# Comma-separated. Generate one with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_TOKENS=CHANGE_ME_AGENT_TOKEN

GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_ALLOWED_EMAILS=0xporky@gmail.com
GOOGLE_ALLOWED_DOMAINS=

ACCESS_TOKEN_EXPIRE_MINUTES=60
WS_SESSION_TIMEOUT_SECONDS=3600

# ── App build-time (web, baked into bundle) ────────────────────────
# These are derived from DOMAIN/SUBDOMAIN by up.sh and do not need edits.
# They appear here only as documentation.
# VITE_API_URL=https://rc.example.com
# VITE_WS_URL=wss://rc.example.com
# VITE_GOOGLE_CLIENT_ID=<uses GOOGLE_CLIENT_ID>
